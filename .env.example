# poprink nano — copy to .env and edit

# server
PORT=3000
HOST=0.0.0.0

# tmdb (optional — built-in fallback exists)
# TMDB_API_KEY=
# TMDB_ACCESS_TOKEN=

# database (optional — defaults to local json)
# DATABASE_URL=
# DATABASE_TYPE=json

# site
SITE_NAME=poprink
METADATA_TITLE=poprink nano
METADATA_DESCRIPTION=a minimalist web interface for poprink. search for movies and tv shows instantly without bloat.
METADATA_THUMBNAIL=/icons/nano-pet.svg
DEFAULT_LOCALE=en

# theme palette: monochrome (black & white) or color
THEME_PALETTE=color

# accent hue 0-360 (light blue ~200)
THEME_HUE=200

# color scheme: dark or light
THEME_MODE=dark

# background colors
COLOR_BG_DARK=#000000
COLOR_BG_LIGHT=#ffffff

# background style:
#   falling       — animated falling dither dots (shader, default)
#   neon-dither   — animated wave dither (shader)
#   dots          — static dot grid
#   lines         — static line grid
#   thin-lines    — static thin line grid
#   text          — repeating poprink text pattern
#   grain         — subtle noise grain
#   none          — solid background only
THEME_BG_STYLE=neon-dither

# optional custom background image url (overrides pattern when set)
# THEME_CUSTOM_BG=

# optional site font family
# THEME_FONT_FAMILY=

# home greeting:
#   nano-pet      — animated mesh pet (default)
#   slogans       — rotating greeting slogans
#   logo          — poprink logo
#   icon          — react-icons custom icon
#   gif           — custom gif image
#   logo-and-icon — icon + site name
GREETING_STYLE=nano-pet
SHOW_GREETING=true

# logo options
SHOW_ICON=false
USE_MIXED_FANCY_FONT=true
LOGO_SIZE=lg
# CUSTOM_ICON=tv
# CUSTOM_GIF=
# CUSTOM_GIF_WIDTH=
# CUSTOM_GIF_HEIGHT=
# CUSTOM_GIF_MARGIN=
# LOGO_FONT_FAMILY=

# header controls
HEADER_SHOW_THEME_TOGGLE=true
HEADER_SHOW_COLOR_PICKER=true
HEADER_SHOW_LANG_SELECTOR=true

# features
SHOW_WATERMARKS=false
SHOW_TRENDING=false
SHOW_QUICK_TAGS=false
ENABLE_AUTH=false
ENABLE_LOCAL_LIBRARY=false
ENABLE_LOCAL_LIBRARY_EDITING=false

# player
AUTOPLAY=true
USE_VIDSTACK=false
DEFAULT_SERVER=nemu
