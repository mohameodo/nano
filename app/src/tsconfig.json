{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@lynx-js/react",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "target": "ES2022",
    "types": ["@lynx-js/types"],
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.css"
  ]
}
